#!/bin/bash
# generated by CloudAI@__CLOUDAI_VERSION__
#SBATCH --job-name=__JOB_NAME__
#SBATCH --output=__OUTPUT_DIR__/stdout.txt
#SBATCH --error=__OUTPUT_DIR__/stderr.txt
#SBATCH --partition=main
#SBATCH -N 3
#SBATCH --gpus-per-node=8
#SBATCH --gres=gpu:8

export SLURM_JOB_MASTER_NODE=$(scontrol show hostname $SLURM_JOB_NODELIST | head -n 1)

nodes=( $( scontrol show hostnames $SLURM_JOB_NODELIST ) )
nodes_array=($nodes)
master_node=${nodes_array[0]}
master_ip=$(srun --nodes=1 --ntasks=1 -w "$master_node" hostname --ip-address | awk '{print $1}')

echo Nodes: $SLURM_JOB_NODELIST
echo Num Nodes: ${#nodes[@]}
echo Master Node: $master_node
echo Master IP: $master_ip

export LD_LIBRARY_PATH=/workspace/rdma_core/lib:$LD_LIBRARY_PATH
srun --export=ALL --mpi=pmix -N3 --container-image=docker.io/nvidia/nixl-ep:latest --container-mounts=__OUTPUT_DIR__:/cloudai_run_results,__INSTALL_DIR__:/cloudai_install,__OUTPUT_DIR__ --no-container-mount-home --output=__OUTPUT_DIR__/mapping-stdout.txt --error=__OUTPUT_DIR__/mapping-stderr.txt bash -c "echo \$(date): \$(hostname):node \${SLURM_NODEID}:rank \${SLURM_PROCID}."

srun --export=ALL --mpi=pmix -N3 --container-image=docker.io/nvidia/nixl-ep:latest --container-mounts=__OUTPUT_DIR__:/cloudai_run_results,__INSTALL_DIR__:/cloudai_install,__OUTPUT_DIR__ --no-container-mount-home --ntasks=3 --ntasks-per-node=1 --output=__OUTPUT_DIR__/metadata/node-%N.toml --error=__OUTPUT_DIR__/metadata/nodes.err bash /cloudai_install/slurm-metadata.sh

wait_for_master_services() {
    local timeout=90
    local interval=1
    local end_time=$(($(date +%s) + timeout))

    while [ "$(date +%s)" -lt "$end_time" ]; do
        if timeout 1 bash -c ": > /dev/tcp/$master_ip/9999" >/dev/null 2>&1; then
            echo "NIXL EP master services are ready on $master_ip"
            return 0
        fi
        sleep "$interval"
    done

    echo "Timed out waiting for NIXL EP master services on $master_ip"
    return 1
}

worker_pids=()

echo "Starting NIXL EP on the master node..."
srun --export=ALL --mpi=pmix --container-image=docker.io/nvidia/nixl-ep:latest --container-mounts=__OUTPUT_DIR__:/cloudai_run_results,__INSTALL_DIR__:/cloudai_install,__OUTPUT_DIR__ --no-container-mount-home --overlap --nodelist=$SLURM_JOB_MASTER_NODE --ntasks-per-node=1 --ntasks=1 -N1 --output=__OUTPUT_DIR__/nixl-ep-node-0.log bash -c "source __OUTPUT_DIR__/env_vars.sh; python3 /workspace/nixl/examples/device/ep/tests/elastic/elastic.py --plan __OUTPUT_DIR__/nixl-ep-plan.json --num-processes 4 --disable-ll-nvlink --hidden-dim 8192 --kineto --num-experts-per-rank 4 --num-tokens 256 --num-topk 6" &
worker_pids+=($!)

echo "Waiting for NIXL EP master services..."
wait_for_master_services || exit 1

echo "Starting NIXL EP follower nodes..."
srun --export=ALL --mpi=pmix --container-image=docker.io/nvidia/nixl-ep:latest --container-mounts=__OUTPUT_DIR__:/cloudai_run_results,__INSTALL_DIR__:/cloudai_install,__OUTPUT_DIR__ --no-container-mount-home --overlap --relative=1 --ntasks-per-node=1 --ntasks=1 -N1 --output=__OUTPUT_DIR__/nixl-ep-node-1.log bash -c "source __OUTPUT_DIR__/env_vars.sh; python3 /workspace/nixl/examples/device/ep/tests/elastic/elastic.py --plan __OUTPUT_DIR__/nixl-ep-plan.json --num-processes 4 --tcp-server $master_ip --disable-ll-nvlink --hidden-dim 8192 --kineto --num-experts-per-rank 4 --num-tokens 256 --num-topk 6" &
worker_pids+=($!)
srun --export=ALL --mpi=pmix --container-image=docker.io/nvidia/nixl-ep:latest --container-mounts=__OUTPUT_DIR__:/cloudai_run_results,__INSTALL_DIR__:/cloudai_install,__OUTPUT_DIR__ --no-container-mount-home --overlap --relative=2 --ntasks-per-node=1 --ntasks=1 -N1 --output=__OUTPUT_DIR__/nixl-ep-node-2.log bash -c "source __OUTPUT_DIR__/env_vars.sh; python3 /workspace/nixl/examples/device/ep/tests/elastic/elastic.py --plan __OUTPUT_DIR__/nixl-ep-plan.json --num-processes 2 --tcp-server $master_ip --disable-ll-nvlink --hidden-dim 8192 --kineto --num-experts-per-rank 4 --num-tokens 256 --num-topk 6" &
worker_pids+=($!)

rc=0
for pid in "${worker_pids[@]}"; do
    wait "$pid" || rc=$?
done

exit $rc
